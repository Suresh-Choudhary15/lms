# Local SQLite database location (relative to prisma/ directory).
# Used when TURSO_DATABASE_URL is not set — fine for local dev.
DATABASE_URL="file:./dev.db"

# Production: point at a hosted Turso (libSQL) database instead of local
# SQLite, since serverless hosts (Vercel/Netlify/Cloudflare) wipe the local
# filesystem between invocations. Get these from `turso db show <name>` and
# `turso db tokens create <name>`. When set, these take priority over
# DATABASE_URL.
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Secret used to sign session cookies. Generate a strong random value for production.
AUTH_SECRET="replace-with-a-long-random-string"