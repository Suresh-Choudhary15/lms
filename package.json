    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.19.0",
    "eslint-config-next": "15.1.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.0.3",
